# ──────────────────────────────────────────────────────────────
# MonStar Ship — All Environment Variables (one file)
# Copy this to .env and fill in your real values.
#
# VITE_ prefix   → exposed to the browser (frontend)
# No VITE_ prefix → used by Firebase Functions only (server-side)
# ──────────────────────────────────────────────────────────────

# ── Firebase (Frontend) ───────────────────────────────────────
# Get from: Firebase Console > Project Settings > Your App
VITE_FIREBASE_API_KEY=YOUR_API_KEY
VITE_FIREBASE_AUTH_DOMAIN=YOUR_PROJECT_ID.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=YOUR_PROJECT_ID
VITE_FIREBASE_STORAGE_BUCKET=YOUR_PROJECT_ID.firebasestorage.app
VITE_FIREBASE_MESSAGING_SENDER_ID=YOUR_MESSAGING_SENDER_ID
VITE_FIREBASE_APP_ID=YOUR_APP_ID

# ── Cloudinary (Frontend) ─────────────────────────────────────
# Get from: Cloudinary Console > Settings > Upload
VITE_CLOUDINARY_CLOUD_NAME=YOUR_CLOUD_NAME
VITE_CLOUDINARY_UPLOAD_PRESET=YOUR_UNSIGNED_UPLOAD_PRESET

# ── SMTP Email (Firebase Functions — server-side only) ────────
# Gmail setup: Google Account > Security > 2-Step > App Passwords
# Outlook: SMTP_HOST=smtp.office365.com, SMTP_PORT=587, SMTP_SECURE=false
SMTP_HOST=smtp.gmail.com
SMTP_PORT=465
SMTP_SECURE=true
SMTP_USER=your_gmail@gmail.com
SMTP_PASS=xxxx_xxxx_xxxx_xxxx
SMTP_FROM_NAME=MonStar Ship Lines
SMTP_FROM_EMAIL=your_gmail@gmail.com
ADMIN_EMAIL=admin@example.com
